#include <stdio.h>
#include <string.h>

int main() {
    int n, i, time = 0, completed = 0;
    
    printf("Enter number of processes: ");
    scanf("%d", &n);

    char pid[n][5];
    int at[n], bt[n], rt[n];
    int wt[n], tat[n], ct[n];

    // Input
    for(i = 0; i < n; i++) {
        scanf("%s %d %d", pid[i], &at[i], &bt[i]);
        rt[i] = bt[i];  // Remaining time initialized
    }

    int min_index;
    int min_time;

    // SRTF Scheduling
    while(completed < n) {
        min_time = 9999;
        min_index = -1;

        for(i = 0; i < n; i++) {
            if(at[i] <= time && rt[i] > 0 && rt[i] < min_time) {
                min_time = rt[i];
                min_index = i;
            }
        }

        if(min_index == -1) {
            time++;
            continue;
        }

        // Execute process for 1 unit
        rt[min_index]--;
        time++;

        // If process completes
        if(rt[min_index] == 0) {
            completed++;
            ct[min_index] = time;

            tat[min_index] = ct[min_index] - at[min_index];
            wt[min_index] = tat[min_index] - bt[min_index];
        }
    }

    float total_wt = 0, total_tat = 0;

    printf("\nWaiting Time:\n");
    for(i = 0; i < n; i++) {
        printf("%s  %d\n", pid[i], wt[i]);
        total_wt += wt[i];
    }

    printf("Turnaround Time:\n");
    for(i = 0; i < n; i++) {
        printf("%s  %d\n", pid[i], tat[i]);
        total_tat += tat[i];
    }

    printf("Average Waiting Time: %.1f\n", total_wt / n);
    printf("Average Turnaround Time: %.1f\n", total_tat / n);

    return 0;
}
